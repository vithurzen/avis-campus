{% extends 'layout/app.html.twig' %}

{% block title %}Cours — Avis Campus{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Catalogue des cours</h1>
            <p class="text-sm text-gray-500 mt-1" id="course-count">{{ courses|length }} cours disponible{{ courses|length > 1 ? 's' : '' }}</p>
        </div>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_course_new') }}"
               class="bg-brand hover:bg-brandHover text-white font-semibold text-sm px-5 py-2.5 rounded-full transition">
                <i class="fa-solid fa-plus mr-1"></i> Nouveau cours
            </a>
        {% endif %}
    </div>

    {# ── Barre de recherche ── #}
    <div class="relative mb-8 max-w-md">
        <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"></i>
        <input type="search"
               id="course-search"
               placeholder="Rechercher un cours, une formation, un tag…"
               class="w-full pl-10 pr-4 py-2.5 text-sm border border-gray-200 rounded-full focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand bg-white">
    </div>

    {% if courses is empty %}
        <div class="text-center py-24 text-gray-400">
            <i class="fa-solid fa-book text-5xl mb-4 opacity-20"></i>
            <p class="text-sm">Aucun cours disponible pour le moment.</p>
        </div>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="courses-grid">
            {% for course in courses %}
                <a href="{{ path('app_course_show', { id: course.id }) }}"
                   data-name="{{ course.title|lower }} {{ course.semester ? course.semester.formation.name|lower : '' }} {% for tag in course.tags %}{{ tag.name|lower }} {% endfor %}"
                   class="course-card group bg-white rounded-2xl border border-gray-200 p-6 hover:shadow-md transition flex flex-col gap-4">

                    <h2 class="text-base font-semibold text-gray-900 group-hover:text-brand transition line-clamp-2">
                        {{ course.title }}
                    </h2>

                    {% if course.tags is not empty %}
                        <div class="flex flex-wrap gap-1">
                            {% for tag in course.tags %}
                                <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium"
                                      style="background-color: {{ tag.color }}22; color: {{ tag.color }}">
                                    {{ tag.name }}
                                </span>
                            {% endfor %}
                        </div>
                    {% endif %}

                    {% if course.description %}
                        <p class="text-sm text-gray-500 line-clamp-2">{{ course.description }}</p>
                    {% endif %}

                    <div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-between text-xs text-gray-400">
                        <span>
                            <i class="fa-solid fa-graduation-cap mr-1"></i>
                            {{ course.semester ? course.semester.formation.name : '—' }}
                        </span>
                        <div class="flex items-center gap-3">
                            {% if course.hours %}
                                <span><i class="fa-regular fa-clock mr-1"></i>{{ course.hours }}h</span>
                            {% endif %}
                            {% if course.coefficient %}
                                <span>Coef. {{ course.coefficient }}</span>
                            {% endif %}
                        </div>
                    </div>

                </a>
            {% endfor %}
        </div>

        <p class="text-center text-sm text-gray-400 mt-10 hidden" id="no-results">Aucun cours ne correspond à votre recherche.</p>
    {% endif %}

</div>

<script>
(function () {
    const input   = document.getElementById('course-search');
    const cards   = document.querySelectorAll('.course-card');
    const noRes   = document.getElementById('no-results');
    const counter = document.getElementById('course-count');

    if (!input) return;

    input.addEventListener('input', () => {
        const q = input.value.trim().toLowerCase();
        let visible = 0;
        cards.forEach(card => {
            const match = !q || card.dataset.name.includes(q);
            card.style.display = match ? '' : 'none';
            if (match) visible++;
        });
        noRes.classList.toggle('hidden', visible > 0);
        counter.textContent = visible + ' cours disponible' + (visible > 1 ? 's' : '');
    });
})();
</script>
{% endblock %}
