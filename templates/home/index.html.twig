{% extends 'layout/app.html.twig' %}

{% block title %}Avis Campus — Accueil{% endblock %}

{% block content %}
<section class="bg-gradient-to-br from-brand to-brandHover text-white py-24 px-4 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold mb-4">Avis Campus</h1>
    <p class="text-lg text-indigo-100 max-w-xl mx-auto mb-8">
        Consultez et partagez des avis sur les cours de votre formation.
    </p>
    <div class="flex items-center justify-center gap-4 flex-wrap">
        <a href="{{ path('app_course_index') }}"
           class="bg-white text-brand font-semibold px-6 py-3 rounded-full hover:bg-gray-100 transition text-sm">
            Parcourir les cours
        </a>
        {% if not app.user %}
            <a href="{{ path('app_register') }}"
               class="border border-white text-white font-semibold px-6 py-3 rounded-full hover:bg-white hover:text-brand transition text-sm">
                Créer un compte
            </a>
        {% else %}
            <a href="{{ path('app_review_new') }}"
               class="border border-white text-white font-semibold px-6 py-3 rounded-full hover:bg-white hover:text-brand transition text-sm">
                Déposer un avis
            </a>
        {% endif %}
    </div>
</section>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
        <div>
            <div class="text-4xl font-bold text-brand mb-2">
                <i class="fa-solid fa-book"></i>
            </div>
            <h3 class="font-semibold text-gray-900 mb-1">Des cours notés</h3>
            <p class="text-sm text-gray-500">Chaque cours est évalué selon plusieurs critères par les étudiants.</p>
        </div>
        <div>
            <div class="text-4xl font-bold text-brand mb-2">
                <i class="fa-solid fa-star"></i>
            </div>
            <h3 class="font-semibold text-gray-900 mb-1">Des avis vérifiés</h3>
            <p class="text-sm text-gray-500">Les avis sont modérés pour garantir leur qualité et leur pertinence.</p>
        </div>
        <div>
            <div class="text-4xl font-bold text-brand mb-2">
                <i class="fa-solid fa-users"></i>
            </div>
            <h3 class="font-semibold text-gray-900 mb-1">Une communauté étudiante</h3>
            <p class="text-sm text-gray-500">Partagez votre expérience et aidez les autres à choisir leurs cours.</p>
        </div>
    </div>
</section>
{% endblock %}
