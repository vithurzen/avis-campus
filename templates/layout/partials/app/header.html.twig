<header class="sticky top-0 z-50 bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">

            <a href="{{ path('app_home') }}" class="flex items-center gap-2 font-bold text-xl text-brand">
                <i class="fa-solid fa-graduation-cap"></i>
                Avis Campus
            </a>

            <nav class="hidden md:flex items-center gap-6">
                <a href="{{ path('app_formation_index') }}"
                   class="text-sm text-gray-600 hover:text-brand transition {{ app.request.attributes.get('_route') starts with 'app_formation' ? 'text-brand font-semibold' : '' }}">
                    Formations
                </a>
                <a href="{{ path('app_course_index') }}"
                   class="text-sm text-gray-600 hover:text-brand transition {{ app.request.attributes.get('_route') starts with 'app_course' ? 'text-brand font-semibold' : '' }}">
                    Cours
                </a>
                <a href="{{ path('app_review_index') }}"
                   class="text-sm text-gray-600 hover:text-brand transition {{ app.request.attributes.get('_route') starts with 'app_review' ? 'text-brand font-semibold' : '' }}">
                    Avis
                </a>
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_admin_users') }}"
                       class="text-sm text-gray-600 hover:text-brand transition {{ app.request.attributes.get('_route') starts with 'app_admin' ? 'text-brand font-semibold' : '' }}">
                        Admin
                    </a>
                {% endif %}
            </nav>

            <div class="flex items-center gap-3">
                {% if app.user %}
                    <a href="{{ path('app_favorite_index') }}"
                       class="relative inline-flex items-center justify-center text-red-400 hover:text-red-500 transition"
                       title="Mes favoris">
                        {% set favCount = app.user.favorites|length %}
                        <i class="fa-solid fa-heart text-base"></i>
                        {% if favCount > 0 %}
                            <span class="absolute inset-0 flex items-center justify-center text-white font-black leading-none" style="font-size:{{ favCount > 9 ? 6 : 8 }}px;padding-bottom:1px">
                                {{ favCount > 99 ? '99' : favCount }}
                            </span>
                        {% endif %}
                    </a>
                    <span class="text-sm text-gray-500 hidden sm:block">{{ app.user.email }}</span>
                    <a href="{{ path('app_logout') }}"
                       class="text-sm text-gray-600 hover:text-brand transition"
                       title="Déconnexion">
                        <i class="fa-solid fa-right-from-bracket"></i>
                    </a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="text-sm text-gray-700 hover:text-brand transition font-medium">
                        Connexion
                    </a>
                    <a href="{{ path('app_register') }}" class="text-sm bg-brand hover:bg-brandHover text-white px-4 py-2 rounded-full transition font-medium">
                        S'inscrire
                    </a>
                {% endif %}
            </div>

        </div>
    </div>
</header>
