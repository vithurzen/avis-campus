{% extends 'layout/app.html.twig' %}

{% block title %}Formations — Avis Campus{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Formations</h1>
            <p class="text-sm text-gray-500 mt-1" id="formation-count">{{ formations|length }} formation{{ formations|length > 1 ? 's' : '' }}</p>
        </div>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_formation_new') }}"
               class="bg-brand hover:bg-brandHover text-white font-semibold text-sm px-5 py-2.5 rounded-full transition">
                <i class="fa-solid fa-plus mr-1"></i> Nouvelle formation
            </a>
        {% endif %}
    </div>

    {# ── Barre de recherche ── #}
    <div class="bg-white border border-gray-200 rounded-2xl p-4 mb-6 flex flex-wrap gap-3 items-center">
        <div class="relative flex-1 min-w-[180px]">
            <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"></i>
            <input type="search"
                   id="formation-search"
                   placeholder="Rechercher une formation…"
                   class="w-full pl-9 pr-3 py-2.5 text-sm border border-gray-200 rounded-lg focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand bg-white">
        </div>
    </div>

    {% if formations is empty %}
        <div class="text-center py-24 text-gray-400">
            <i class="fa-solid fa-graduation-cap text-5xl mb-4 opacity-20"></i>
            <p class="text-sm">Aucune formation disponible.</p>
        </div>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="formations-grid">
            {% for formation in formations %}
                <a href="{{ path('app_formation_show', { id: formation.id }) }}"
                   data-name="{{ formation.name|lower }} {{ formation.degreeLevel|lower }}"
                   class="formation-card group bg-white rounded-2xl border border-gray-200 p-6 hover:shadow-md transition flex flex-col gap-4">

                    <div>
                        {% if formation.degreeLevel %}
                            <span class="inline-block px-2.5 py-1 rounded-full text-xs font-medium bg-brand/10 text-brand mb-3">
                                {{ formation.degreeLevel }}
                            </span>
                        {% endif %}
                        <h2 class="text-base font-semibold text-gray-900 group-hover:text-brand transition">
                            {{ formation.name }}
                        </h2>
                    </div>

                    {% if formation.description %}
                        <p class="text-sm text-gray-500 line-clamp-2">{{ formation.description }}</p>
                    {% endif %}

                    <div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-between text-xs text-gray-400">
                        <span>
                            <i class="fa-solid fa-layer-group mr-1"></i>
                            {{ formation.semesters|length }} semestre{{ formation.semesters|length > 1 ? 's' : '' }}
                        </span>
                        <span>
                            <i class="fa-solid fa-book mr-1"></i>
                            {% set courseCount = 0 %}
                            {% for semester in formation.semesters %}
                                {% set courseCount = courseCount + semester.courses|length %}
                            {% endfor %}
                            {{ courseCount }} cours
                        </span>
                    </div>

                </a>
            {% endfor %}
        </div>

        <p class="text-center text-sm text-gray-400 mt-10 hidden" id="no-results">Aucune formation ne correspond à votre recherche.</p>
    {% endif %}

</div>

<script>
(function () {
    const input   = document.getElementById('formation-search');
    const cards   = document.querySelectorAll('.formation-card');
    const noRes   = document.getElementById('no-results');
    const counter = document.getElementById('formation-count');

    if (!input) return;

    input.addEventListener('input', () => {
        const q = input.value.trim().toLowerCase();
        let visible = 0;
        cards.forEach(card => {
            const match = !q || card.dataset.name.includes(q);
            card.style.display = match ? '' : 'none';
            if (match) visible++;
        });
        noRes.classList.toggle('hidden', visible > 0);
        counter.textContent = visible + ' formation' + (visible > 1 ? 's' : '');
    });
})();
</script>
{% endblock %}
