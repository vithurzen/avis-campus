{% extends 'layout/app.html.twig' %}

{% block title %}{{ formation.name }} — Avis Campus{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto px-4 sm:px-6 py-10">

    <div class="mb-6">
        <a href="{{ path('app_formation_index') }}" class="text-sm text-gray-500 hover:text-brand transition">
            <i class="fa-solid fa-arrow-left mr-1"></i> Retour aux formations
        </a>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 p-8 mb-8">

        <div class="flex items-start justify-between gap-4 mb-2">
            <div>
                {% if formation.degreeLevel %}
                    <span class="inline-block px-2.5 py-1 rounded-full text-xs font-medium bg-brand/10 text-brand mb-3">
                        {{ formation.degreeLevel }}
                    </span>
                {% endif %}
                <h1 class="text-2xl font-bold text-gray-900">{{ formation.name }}</h1>
            </div>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_formation_edit', { id: formation.id }) }}"
                   class="text-sm bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium px-4 py-2 rounded-full transition shrink-0">
                    <i class="fa-solid fa-pen mr-1"></i> Modifier
                </a>
            {% endif %}
        </div>

        {% if formation.description %}
            <p class="text-sm text-gray-600 leading-relaxed mt-4">{{ formation.description }}</p>
        {% endif %}

    </div>

    {% if formation.semesters is empty %}
        <div class="text-center py-12 text-gray-400 bg-white rounded-2xl border border-gray-200">
            <i class="fa-solid fa-layer-group text-3xl mb-3 opacity-20"></i>
            <p class="text-sm">Aucun semestre pour cette formation.</p>
        </div>
    {% else %}
        <div class="space-y-6">
            {% for semester in formation.semesters %}
                <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">

                    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 bg-gray-50">
                        <h2 class="font-semibold text-gray-900">{{ semester.name }}</h2>
                        <span class="text-xs text-gray-400">{{ semester.courses|length }} cours</span>
                    </div>

                    {% if semester.courses is empty %}
                        <p class="text-sm text-gray-400 px-6 py-4">Aucun cours dans ce semestre.</p>
                    {% else %}
                        <div class="divide-y divide-gray-100">
                            {% for course in semester.courses %}
                                <a href="{{ path('app_course_show', { id: course.id }) }}"
                                   class="flex items-center justify-between px-6 py-4 hover:bg-gray-50 transition group">
                                    <div class="flex items-center gap-3 min-w-0">
                                        <span class="text-sm font-medium text-gray-900 group-hover:text-brand transition truncate">
                                            {{ course.title }}
                                        </span>
                                        {% for tag in course.tags %}
                                            <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium shrink-0"
                                                  style="background-color: {{ tag.color }}22; color: {{ tag.color }}">
                                                {{ tag.name }}
                                            </span>
                                        {% endfor %}
                                    </div>
                                    <div class="flex items-center gap-4 text-xs text-gray-400 shrink-0 ml-4">
                                        {% if course.hours %}
                                            <span><i class="fa-regular fa-clock mr-1"></i>{{ course.hours }}h</span>
                                        {% endif %}
                                        {% if course.coefficient %}
                                            <span>Coef. {{ course.coefficient }}</span>
                                        {% endif %}
                                    </div>
                                </a>
                            {% endfor %}
                        </div>
                    {% endif %}

                </div>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
