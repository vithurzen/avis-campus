{% extends 'layout/app.html.twig' %}

{% block title %}{{ review.title }} — Avis Campus{% endblock %}

{% block content %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 py-10">

    <div class="mb-6">
        <a href="{{ path('app_review_index') }}" class="text-sm text-gray-500 hover:text-brand transition">
            <i class="fa-solid fa-arrow-left mr-1"></i> Retour aux avis
        </a>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 p-8 mb-6">

        <div class="flex items-start justify-between gap-4 mb-6">
            <h1 class="text-2xl font-bold text-gray-900">{{ review.title }}</h1>
            {% if review.status == 'approved' %}
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium shrink-0 bg-green-100 text-green-700">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Approuvé
                </span>
            {% elseif review.status == 'pending' %}
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium shrink-0 bg-amber-100 text-amber-700">
                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span> En attente
                </span>
            {% elseif review.status == 'rejected' %}
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium shrink-0 bg-red-100 text-red-700">
                    <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span> Rejeté
                </span>
            {% elseif review.status == 'hidden' %}
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium shrink-0 bg-gray-100 text-gray-500">
                    <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span> Masqué
                </span>
            {% endif %}
        </div>

        <div class="flex items-center gap-4 text-xs text-gray-400 mb-4 flex-wrap">
            {% if review.course %}
                <a href="{{ path('app_course_show', { id: review.course.id }) }}"
                   class="hover:text-brand transition flex items-center gap-1">
                    <i class="fa-solid fa-book"></i>{{ review.course.title }}
                </a>
            {% else %}
                <span><i class="fa-solid fa-book mr-1"></i>—</span>
            {% endif %}
            <span><i class="fa-solid fa-user mr-1"></i>
                {% set profile = review.user.profile %}
                {{ profile ? (profile.firstName ~ ' ' ~ profile.lastName) : review.user.email }}
            </span>
            <span><i class="fa-regular fa-calendar mr-1"></i>{{ review.createdAt ? review.createdAt|date('d/m/Y') : '' }}</span>
        </div>

        {% if review.rating %}
            <div class="flex items-center gap-2 mb-6">
                <span class="text-xl leading-none tracking-tight">
                    {% for i in 1..5 %}
                        <span class="{{ i <= review.rating ? 'text-amber-400' : 'text-gray-200' }}">★</span>
                    {% endfor %}
                </span>
                <span class="text-sm font-semibold text-gray-700">{{ review.rating }}/5</span>
            </div>
        {% endif %}

        <p class="text-sm text-gray-700 leading-relaxed whitespace-pre-line">{{ review.content }}</p>

        <div class="mt-8 pt-6 border-t border-gray-100 flex items-center gap-3 flex-wrap">
            {% if is_granted('REVIEW_EDIT', review) %}
                <a href="{{ path('app_review_edit', { id: review.id }) }}"
                   class="text-sm bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium px-4 py-2 rounded-full transition">
                    <i class="fa-solid fa-pen mr-1"></i> Modifier
                </a>
            {% endif %}
            {% if is_granted('REVIEW_DELETE', review) %}
                <form method="post" action="{{ path('app_review_delete', { id: review.id }) }}"
                      onsubmit="return confirm('Supprimer cet avis ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ review.id) }}">
                    <button type="submit"
                            class="text-sm bg-red-50 hover:bg-red-100 text-red-600 font-medium px-4 py-2 rounded-full transition">
                        <i class="fa-solid fa-trash mr-1"></i> Supprimer
                    </button>
                </form>
            {% endif %}
            {% if is_granted('ROLE_USER') and app.user != review.user %}
                <button type="button" id="report-btn"
                        class="ml-auto text-sm text-gray-400 hover:text-red-500 transition flex items-center gap-1.5">
                    <i class="fa-solid fa-flag text-xs"></i> Signaler
                </button>
            {% endif %}
        </div>

    </div>

    <div>
        <h2 class="text-lg font-semibold text-gray-900 mb-4">
            Commentaires
            <span class="text-sm font-normal text-gray-400 ml-1">({{ review.comments|length }})</span>
        </h2>

        {% if review.comments is empty %}
            <div class="text-center py-12 text-gray-400 bg-white rounded-2xl border border-gray-200">
                <i class="fa-regular fa-comment text-3xl mb-3 opacity-30"></i>
                <p class="text-sm">Aucun commentaire pour le moment.</p>
            </div>
        {% else %}
            <div class="space-y-4">
                {% for comment in review.comments %}
                    {% if comment.status == 'visible' %}
                        <div class="bg-white rounded-xl border border-gray-200 p-5">
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex items-center gap-2">
                                    <div class="w-7 h-7 rounded-full bg-brand flex items-center justify-center text-white text-xs font-bold">
                                        {% set cp = comment.user.profile %}
                                        {{ cp ? (cp.firstName|first ~ cp.lastName|first)|upper : comment.user.email|first|upper }}
                                    </div>
                                    <span class="text-sm font-medium text-gray-800">
                                        {% set cp = comment.user.profile %}
                                        {{ cp ? (cp.firstName ~ ' ' ~ cp.lastName) : comment.user.email }}
                                    </span>
                                </div>
                                <span class="text-xs text-gray-400">
                                    {{ comment.createdAt ? comment.createdAt|date('d/m/Y') : '' }}
                                    {% if comment.updatedAt %}
                                        <span class="italic ml-1">(modifié)</span>
                                    {% endif %}
                                </span>
                            </div>
                            <p class="text-sm text-gray-700">{{ comment.content }}</p>
                            {% if is_granted('COMMENT_EDIT', comment) or is_granted('COMMENT_DELETE', comment) %}
                                <div class="flex items-center gap-3 mt-3 pt-3 border-t border-gray-100">
                                    {% if is_granted('COMMENT_EDIT', comment) %}
                                        <a href="{{ path('app_comment_edit', { id: comment.id }) }}"
                                           class="text-xs text-gray-400 hover:text-gray-700 transition flex items-center gap-1">
                                            <i class="fa-solid fa-pen text-[10px]"></i> Modifier
                                        </a>
                                    {% endif %}
                                    {% if is_granted('COMMENT_DELETE', comment) %}
                                        <form method="post"
                                              action="{{ path('app_comment_delete', { id: comment.id }) }}"
                                              onsubmit="return confirm('Supprimer ce commentaire ?')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ comment.id) }}">
                                            <button type="submit"
                                                    class="text-xs text-red-400 hover:text-red-600 transition flex items-center gap-1">
                                                <i class="fa-solid fa-trash text-[10px]"></i> Supprimer
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {# — Formulaire d'ajout de commentaire — #}
    <div class="mt-6">
        {% if is_granted('ROLE_USER') %}
            <h3 class="text-base font-semibold text-gray-900 mb-3">Laisser un commentaire</h3>
            {{ form_start(commentForm, {
                action: path('app_comment_new'),
                attr: { class: 'space-y-3' }
            }) }}
                <input type="hidden" name="reviewId" value="{{ review.id }}">
                <div>
                    {{ form_widget(commentForm.content, {
                        attr: {
                            class: 'w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand bg-white resize-none',
                            rows: 3,
                            placeholder: 'Rédigez votre commentaire…'
                        }
                    }) }}
                    {{ form_errors(commentForm.content) }}
                </div>
                <div class="flex justify-end">
                    <button type="submit"
                            class="bg-brand hover:bg-brandHover text-white text-sm font-semibold px-5 py-2.5 rounded-full transition">
                        <i class="fa-solid fa-paper-plane mr-1.5"></i> Publier
                    </button>
                </div>
            {{ form_end(commentForm) }}
        {% else %}
            <div class="text-center py-6 bg-gray-50 rounded-xl border border-gray-200">
                <p class="text-sm text-gray-500">
                    <a href="{{ path('app_login') }}" class="text-brand hover:underline font-medium">Connectez-vous</a>
                    pour laisser un commentaire.
                </p>
            </div>
        {% endif %}
    </div>

</div>

{% if is_granted('ROLE_USER') and app.user != review.user %}
{# ── Modale signalement ── #}
<div id="modal-report" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="modal-report-backdrop"></div>
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-md mx-4 p-6">

        <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center shrink-0">
                <i class="fa-solid fa-flag text-red-500"></i>
            </div>
            <div>
                <h3 class="font-semibold text-gray-900">Signaler cet avis</h3>
                <p class="text-xs text-gray-400 mt-0.5 line-clamp-1">« {{ review.title }} »</p>
            </div>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 text-sm px-3 py-2.5 rounded-lg border
                    {{ label == 'success' ? 'bg-green-50 border-green-200 text-green-700' : '' }}
                    {{ label == 'error'   ? 'bg-red-50 border-red-200 text-red-600' : '' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {{ form_start(reportForm, { action: path('app_report_new'), method: 'POST', attr: { class: 'space-y-4' } }) }}
            {{ form_widget(reportForm.reviewId, { value: review.id }) }}

            <div>
                <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">
                    Motif <span class="text-red-500">*</span>
                </label>
                {{ form_widget(reportForm.reason, {
                    attr: { class: 'w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand bg-white' }
                }) }}
                {{ form_errors(reportForm.reason) }}
            </div>

            <div>
                <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">
                    Précisions <span class="text-xs font-normal text-gray-400">(optionnel)</span>
                </label>
                {{ form_widget(reportForm.description, {
                    attr: { class: 'w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand resize-none' }
                }) }}
            </div>

            <div class="flex items-center justify-end gap-3 pt-2">
                <button type="button" id="modal-report-cancel"
                        class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 transition">
                    Annuler
                </button>
                <button type="submit"
                        class="px-5 py-2 text-sm font-semibold bg-red-500 hover:bg-red-600 text-white rounded-full transition">
                    Envoyer le signalement
                </button>
            </div>
        {{ form_end(reportForm) }}

    </div>
</div>

<script>
(function () {
    const modal    = document.getElementById('modal-report');
    const openBtn  = document.getElementById('report-btn');
    const closeBtn = document.getElementById('modal-report-cancel');
    const backdrop = document.getElementById('modal-report-backdrop');

    if (!openBtn) return;

    openBtn.addEventListener('click', () => modal.classList.remove('hidden'));
    closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });

    function close() { modal.classList.add('hidden'); }
})();
</script>
{% endif %}

{% endblock %}
