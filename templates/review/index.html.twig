{% extends 'layout/app.html.twig' %}

{% block title %}Avis — Avis Campus{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Avis étudiants</h1>
            <p class="text-sm text-gray-500 mt-1" id="review-count">{{ reviews|length }} avis publié{{ reviews|length > 1 ? 's' : '' }}</p>
        </div>
        {% if is_granted('ROLE_USER') %}
            <a href="{{ path('app_review_new') }}"
               class="bg-brand hover:bg-brandHover text-white font-semibold text-sm px-5 py-2.5 rounded-full transition">
                <i class="fa-solid fa-plus mr-1"></i> Déposer un avis
            </a>
        {% endif %}
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 text-sm px-4 py-3 rounded-lg border
                {{ label == 'warning' ? 'bg-amber-50 border-amber-200 text-amber-700' : '' }}
                {{ label == 'info'    ? 'bg-blue-50 border-blue-200 text-blue-700' : '' }}
                {{ label == 'success' ? 'bg-green-50 border-green-200 text-green-700' : '' }}
                {{ label == 'error'   ? 'bg-red-50 border-red-200 text-red-600' : '' }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% if is_granted('ROLE_USER') and myReviews is not empty %}
        <div class="mb-10">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Mes avis</h2>
            <div class="space-y-3">
                {% for review in myReviews %}
                    <div class="bg-white rounded-xl border border-gray-200 px-5 py-4 flex items-center justify-between gap-4">
                        <div class="flex items-center gap-4 min-w-0">
                            {% if review.status == 'approved' %}
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium shrink-0 bg-green-100 text-green-700">
                                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Approuvé
                                </span>
                            {% elseif review.status == 'pending' %}
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium shrink-0 bg-amber-100 text-amber-700">
                                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span> En attente
                                </span>
                            {% elseif review.status == 'rejected' %}
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium shrink-0 bg-red-100 text-red-700">
                                    <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span> Rejeté
                                </span>
                            {% elseif review.status == 'hidden' %}
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium shrink-0 bg-gray-100 text-gray-500">
                                    <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span> Masqué
                                </span>
                            {% endif %}
                            <div class="min-w-0">
                                <p class="text-sm font-semibold text-gray-900 truncate">{{ review.title }}</p>
                                <p class="text-xs text-gray-400">{{ review.course ? review.course.title : '—' }} · {{ review.createdAt ? review.createdAt|date('d/m/Y') : '' }}</p>
                            </div>
                        </div>
                        <a href="{{ path('app_review_show', { id: review.id }) }}"
                           class="text-sm text-brand hover:underline shrink-0">Voir</a>
                    </div>
                {% endfor %}
            </div>
        </div>
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Tous les avis</h2>
    {% endif %}

    {# ── Filtres par étoiles ── #}
    <div class="flex items-center gap-2 mb-4 flex-wrap">
        <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide mr-1">Filtrer :</span>
        <button data-filter="all"
                class="filter-btn active-filter px-4 py-1.5 rounded-full text-sm font-medium border transition">
            Tous
        </button>
        <button data-filter="gte4"
                class="filter-btn px-4 py-1.5 rounded-full text-sm font-medium border border-gray-200 text-gray-600 hover:border-amber-400 hover:text-amber-600 transition">
            <span class="text-amber-400">★★★★</span>+ (≥ 4 étoiles)
        </button>
        <button data-filter="lt4"
                class="filter-btn px-4 py-1.5 rounded-full text-sm font-medium border border-gray-200 text-gray-600 hover:border-gray-400 transition">
            &lt; 4 étoiles
        </button>
        <button data-filter="norating"
                class="filter-btn px-4 py-1.5 rounded-full text-sm font-medium border border-gray-200 text-gray-600 hover:border-gray-400 transition">
            Sans note
        </button>
    </div>

    {# ── Tri ── #}
    <div class="flex items-center gap-2 mb-6 flex-wrap">
        <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide mr-1">Trier :</span>
        <button data-sort="recent"
                class="sort-btn active-sort px-4 py-1.5 rounded-full text-sm font-medium border transition">
            Plus récents
        </button>
        <button data-sort="stars"
                class="sort-btn px-4 py-1.5 rounded-full text-sm font-medium border border-gray-200 text-gray-600 hover:border-amber-400 hover:text-amber-600 transition">
            Plus d'étoiles
        </button>
        <button data-sort="course"
                class="sort-btn px-4 py-1.5 rounded-full text-sm font-medium border border-gray-200 text-gray-600 hover:border-gray-400 transition">
            Cours (A → Z)
        </button>
        <select id="course-select"
                class="px-3 py-1.5 rounded-full text-sm font-medium border border-gray-200 text-gray-600 bg-white hover:border-gray-400 transition cursor-pointer">
            <option value="">Tous les cours</option>
        </select>
    </div>

    {% if reviews is empty %}
        <div class="text-center py-24 text-gray-400">
            <i class="fa-solid fa-star text-5xl mb-4 opacity-20"></i>
            <p class="text-sm">Aucun avis pour le moment.</p>
        </div>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="reviews-grid">
            {% for review in reviews %}
                <a href="{{ path('app_review_show', { id: review.id }) }}"
                   data-rating="{{ review.rating ?? '' }}"
                   data-created="{{ review.createdAt ? review.createdAt.timestamp : 0 }}"
                   data-course="{{ review.course ? review.course.title|lower : '' }}"
                   data-course-label="{{ review.course ? review.course.title : '' }}"
                   class="review-card group bg-white rounded-2xl border border-gray-200 p-6 hover:shadow-md transition flex flex-col gap-4">

                    <div class="flex items-start justify-between gap-3">
                        <h2 class="text-base font-semibold text-gray-900 group-hover:text-brand transition line-clamp-2">
                            {{ review.title }}
                        </h2>
                    </div>

                    {# Étoiles #}
                    {% if review.rating %}
                        <div class="flex items-center gap-1.5">
                            <span class="text-base leading-none tracking-tight">
                                {% for i in 1..5 %}
                                    <span class="{{ i <= review.rating ? 'text-amber-400' : 'text-gray-200' }}">★</span>
                                {% endfor %}
                            </span>
                            <span class="text-xs font-semibold text-gray-500">{{ review.rating }}/5</span>
                        </div>
                    {% else %}
                        <div class="text-xs text-gray-300 tracking-tight">★★★★★ <span class="text-gray-300 font-normal">Non noté</span></div>
                    {% endif %}

                    <p class="text-sm text-gray-600 line-clamp-3">{{ review.content }}</p>

                    <div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-between text-xs text-gray-400">
                        <span class="truncate"><i class="fa-solid fa-book mr-1"></i>{{ review.course ? review.course.title : '—' }}</span>
                        <span class="flex items-center gap-3 shrink-0">
                            {% if review.comments|length > 0 %}
                                <span title="{{ review.comments|length }} commentaire{{ review.comments|length > 1 ? 's' : '' }}">
                                    <i class="fa-regular fa-comment mr-1"></i>{{ review.comments|length }}
                                </span>
                            {% endif %}
                            <span>{{ review.createdAt ? review.createdAt|date('d/m/Y') : '' }}</span>
                        </span>
                    </div>

                </a>
            {% endfor %}
        </div>

        <p class="text-center text-sm text-gray-400 mt-10 hidden" id="no-results">Aucun avis ne correspond à ce filtre.</p>
    {% endif %}

</div>

<script>
(function () {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const sortButtons    = document.querySelectorAll('.sort-btn');
    const courseSelect   = document.getElementById('course-select');
    const grid     = document.getElementById('reviews-grid');
    const cards    = grid ? Array.from(grid.querySelectorAll('.review-card')) : [];
    const noResult = document.getElementById('no-results');
    const counter  = document.getElementById('review-count');

    const activeClass    = ['bg-brand', 'text-white', 'border-brand'];
    const inactiveClass  = ['border-gray-200', 'text-gray-600'];

    let currentFilter = 'all';
    let currentSort   = 'recent';
    let currentCourse = '';

    // Remplit le select avec les cours réellement présents dans la liste, triés alphabétiquement.
    if (courseSelect) {
        const courses = new Map();
        cards.forEach(card => {
            const value = card.dataset.course;
            const label = card.dataset.courseLabel;
            if (value && !courses.has(value)) courses.set(value, label);
        });
        [...courses.entries()]
            .sort((a, b) => a[1].localeCompare(b[1]))
            .forEach(([value, label]) => {
                const option = document.createElement('option');
                option.value = value;
                option.textContent = label;
                courseSelect.appendChild(option);
            });
    }

    function matchesFilter(card, filter) {
        const r = card.dataset.rating === '' ? null : parseInt(card.dataset.rating, 10);
        if (filter === 'all')       return true;
        if (filter === 'gte4')      return r !== null && r >= 4;
        if (filter === 'lt4')       return r !== null && r < 4;
        if (filter === 'norating')  return r === null;
        return true;
    }

    function render() {
        // Tri : notes décroissantes (5 étoiles en premier), non notés en dernier ; sinon plus récent d'abord.
        const sorted = [...cards].sort((a, b) => {
            if (currentSort === 'stars') {
                const aR = a.dataset.rating === '' ? null : parseInt(a.dataset.rating, 10);
                const bR = b.dataset.rating === '' ? null : parseInt(b.dataset.rating, 10);
                if (aR === null && bR === null) return 0;
                if (aR === null) return 1;
                if (bR === null) return -1;
                return bR - aR;
            }
            if (currentSort === 'course') {
                return a.dataset.course.localeCompare(b.dataset.course);
            }
            return parseInt(b.dataset.created, 10) - parseInt(a.dataset.created, 10);
        });

        let visible = 0;
        sorted.forEach(card => {
            const show = matchesFilter(card, currentFilter) && (!currentCourse || card.dataset.course === currentCourse);
            card.style.display = show ? '' : 'none';
            if (show) visible++;
            grid.appendChild(card);
        });

        noResult.classList.toggle('hidden', visible > 0);
        counter.textContent = visible + ' avis publié' + (visible > 1 ? 's' : '');
    }

    filterButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            filterButtons.forEach(b => {
                b.classList.remove(...activeClass, 'active-filter');
                b.classList.add(...inactiveClass);
            });
            btn.classList.remove(...inactiveClass);
            btn.classList.add(...activeClass, 'active-filter');
            currentFilter = btn.dataset.filter;
            render();
        });
    });

    sortButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            sortButtons.forEach(b => {
                b.classList.remove(...activeClass, 'active-sort');
                b.classList.add(...inactiveClass);
            });
            btn.classList.remove(...inactiveClass);
            btn.classList.add(...activeClass, 'active-sort');
            currentSort = btn.dataset.sort;
            render();
        });
    });

    if (courseSelect) {
        courseSelect.addEventListener('change', () => {
            currentCourse = courseSelect.value;
            render();
        });
    }

    // Style initial des boutons actifs
    document.querySelector('[data-filter="all"]').classList.add(...activeClass);
    document.querySelector('[data-filter="all"]').classList.remove(...inactiveClass);
    document.querySelector('[data-sort="recent"]').classList.add(...activeClass);
    document.querySelector('[data-sort="recent"]').classList.remove(...inactiveClass);
})();
</script>
{% endblock %}
