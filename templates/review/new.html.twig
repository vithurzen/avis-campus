{% extends 'layout/app.html.twig' %}

{% block title %}Déposer un avis — Avis Campus{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto px-4 sm:px-6 py-10">

    <div class="mb-8">
        <a href="{{ path('app_review_index') }}" class="text-sm text-gray-500 hover:text-brand transition">
            <i class="fa-solid fa-arrow-left mr-1"></i> Retour aux avis
        </a>
        <h1 class="text-2xl font-bold text-gray-900 mt-4">Déposer un avis</h1>
        <p class="text-sm text-gray-500 mt-1">Votre avis sera publié immédiatement.</p>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-6 text-sm px-4 py-3 rounded-lg border
                {{ label == 'warning' ? 'bg-amber-50 border-amber-200 text-amber-700' : '' }}
                {{ label == 'success' ? 'bg-green-50 border-green-200 text-green-700' : '' }}
                {{ label == 'error'   ? 'bg-red-50 border-red-200 text-red-600' : '' }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="bg-white rounded-2xl border border-gray-200 p-8">
        {{ form_start(form, { attr: { class: 'space-y-6' } }) }}

            {{ include('review/_cascade.html.twig') }}

            <div>
                {{ form_label(form.title, 'Titre', {
                    label_attr: { class: 'block text-xs font-bold text-gray-700 uppercase tracking-wide mb-1.5' }
                }) }}
                {{ form_widget(form.title, {
                    attr: { class: 'w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand bg-white' }
                }) }}
                <div class="mt-1.5 text-xs text-red-600">{{ form_errors(form.title) }}</div>
            </div>

            <div>
                {{ form_label(form.content, 'Contenu', {
                    label_attr: { class: 'block text-xs font-bold text-gray-700 uppercase tracking-wide mb-1.5' }
                }) }}
                {{ form_widget(form.content, {
                    attr: { class: 'w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand bg-white min-h-[140px]' }
                }) }}
                <div class="mt-1.5 text-xs text-red-600">{{ form_errors(form.content) }}</div>
            </div>

            {# Champ caché alimenté par le widget étoiles #}
            {{ form_widget(form.rating, { attr: { style: 'display:none' } }) }}

            {# Widget étoiles interactif #}
            <div>
                <span class="block text-xs font-bold text-gray-700 uppercase tracking-wide mb-3">Note</span>
                <div class="flex items-center gap-2" id="star-widget">
                    {% for i in 1..5 %}
                        <button type="button"
                                data-value="{{ i }}"
                                aria-label="{{ i }} étoile{{ i > 1 ? 's' : '' }}"
                                class="star-btn text-4xl leading-none focus:outline-none text-gray-300 hover:scale-110 transition-transform"
                        >★</button>
                    {% endfor %}
                </div>
                <p class="mt-2 text-xs text-gray-400" id="star-label">Cliquez pour noter</p>
            </div>

            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="{{ path('app_review_index') }}"
                   class="text-sm text-gray-500 hover:text-gray-700 transition px-4 py-2">
                    Annuler
                </a>
                <button type="submit"
                        class="bg-brand hover:bg-brandHover text-white font-semibold text-sm px-6 py-2.5 rounded-full transition">
                    Soumettre l'avis
                </button>
            </div>

        {{ form_end(form) }}
    </div>

</div>

<script>
(function () {
    const input   = document.getElementById('{{ form.rating.vars.id }}');
    const buttons = document.querySelectorAll('#star-widget .star-btn');
    const label   = document.getElementById('star-label');
    const labels  = ['', 'Mauvais', 'Passable', 'Correct', 'Bien', 'Excellent'];

    let current = 0;

    function paint(n) {
        buttons.forEach((btn, idx) => {
            btn.classList.toggle('text-amber-400', idx < n);
            btn.classList.toggle('text-gray-300',  idx >= n);
        });
    }

    buttons.forEach((btn, idx) => {
        btn.addEventListener('mouseenter', () => paint(idx + 1));
        btn.addEventListener('mouseleave', () => paint(current));
        btn.addEventListener('click', () => {
            current     = idx + 1;
            input.value = current;
            label.textContent = labels[current] + ' — ' + current + '/5';
            label.classList.remove('text-gray-400');
            label.classList.add('text-amber-500', 'font-medium');
            paint(current);
        });
    });
})();
</script>
{% endblock %}
