{% extends 'layout/app.html.twig' %}

{% block title %}Mes favoris — Avis Campus{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Mes favoris</h1>
            <p class="text-sm text-gray-500 mt-1">{{ favorites|length }} cours favori{{ favorites|length > 1 ? 's' : '' }}</p>
        </div>
    </div>

    {% if favorites is empty %}
        <div class="text-center py-24 text-gray-400">
            <i class="fa-regular fa-heart text-5xl mb-4 opacity-20"></i>
            <p class="text-sm">Vous n'avez encore aucun cours en favori.</p>
            <a href="{{ path('app_course_index') }}"
               class="inline-block mt-4 text-sm font-medium text-brand hover:text-brandHover transition">
                Parcourir le catalogue
            </a>
        </div>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for favorite in favorites %}
                {% set course = favorite.course %}
                <div class="group bg-white rounded-2xl border border-gray-200 hover:shadow-md transition flex flex-col">

                    <a href="{{ path('app_course_show', { id: course.id }) }}"
                       class="flex flex-col gap-4 p-6 flex-grow">

                        <div class="flex items-start justify-between gap-2">
                            <h2 class="text-base font-semibold text-gray-900 group-hover:text-brand transition line-clamp-2">
                                {{ course.title }}
                            </h2>
                        </div>

                        {% if course.tags is not empty %}
                            <div class="flex flex-wrap gap-1">
                                {% for tag in course.tags %}
                                    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium"
                                          style="background-color: {{ tag.color }}22; color: {{ tag.color }}">
                                        {{ tag.name }}
                                    </span>
                                {% endfor %}
                            </div>
                        {% endif %}

                        {% if course.description %}
                            <p class="text-sm text-gray-500 line-clamp-2">{{ course.description }}</p>
                        {% endif %}

                    </a>

                    <div class="px-6 pb-5 pt-3 border-t border-gray-100 flex items-center justify-between">
                        <div class="flex items-center gap-3 text-xs text-gray-400">
                            <span>
                                <i class="fa-solid fa-graduation-cap mr-1"></i>
                                {{ course.semester ? course.semester.formation.name : '—' }}
                            </span>
                            <span>
                                <i class="fa-regular fa-clock mr-1"></i>
                                Ajouté le {{ favorite.createdAt ? favorite.createdAt|date('d/m/Y') : '—' }}
                            </span>
                        </div>
                        <form method="post" action="{{ path('app_favorite_remove', { id: favorite.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('unfavorite' ~ favorite.id) }}">
                            <button type="submit"
                                    title="Retirer des favoris"
                                    class="text-red-400 hover:text-red-600 transition text-sm">
                                <i class="fa-solid fa-heart"></i>
                            </button>
                        </form>
                    </div>

                </div>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
