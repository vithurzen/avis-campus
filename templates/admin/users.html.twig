{% extends 'layout/admin.html.twig' %}

{% block title %}Utilisateurs — Administration{% endblock %}

{% block page_title %}Gestion des utilisateurs{% endblock %}

{% block content %}
    {# Stats rapides #}
    {% set totalVerified   = users|filter(u => u.isVerified)|length %}
    {% set totalAdmins     = users|filter(u => 'ROLE_ADMIN' in u.roles)|length %}
    {% set totalModerators = users|filter(u => 'ROLE_MODERATOR' in u.roles)|length %}

    <div class="mb-6">
        <p class="text-sm text-gray-500">{{ users|length }} utilisateur{{ users|length > 1 ? 's' : '' }} au total</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
        <div class="bg-white rounded-xl border border-gray-200 p-5">
            <div class="text-3xl font-bold text-blue-500">{{ users|length }}</div>
            <div class="text-xs text-gray-500 mt-1">Total</div>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-5">
            <div class="text-3xl font-bold text-green-500">{{ totalVerified }}</div>
            <div class="text-xs text-gray-500 mt-1">Vérifiés</div>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-5">
            <div class="text-3xl font-bold text-orange-400">{{ totalModerators }}</div>
            <div class="text-xs text-gray-500 mt-1">Modérateurs</div>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-5">
            <div class="text-3xl font-bold text-red-500">{{ totalAdmins }}</div>
            <div class="text-xs text-gray-500 mt-1">Admins</div>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        {% if users is empty %}
            <div class="text-center py-16 text-gray-400">
                <i class="fa-solid fa-users text-4xl mb-4 opacity-30"></i>
                <p class="text-sm">Aucun utilisateur trouvé.</p>
            </div>
        {% else %}
            <table class="w-full">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">#</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Utilisateur</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Rôle</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Statut</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Avis</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Inscrit le</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for user in users %}
                        {% set profile = user.profile %}
                        {% set initials = profile ? (profile.firstName|first ~ profile.lastName|first) : user.email|first %}

                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-5 py-4 text-sm text-gray-400">{{ user.id }}</td>

                            <td class="px-5 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full bg-brand flex items-center justify-center text-white text-sm font-bold flex-shrink-0">
                                        {{ initials|upper }}
                                    </div>
                                    <div>
                                        <div class="text-sm font-semibold text-gray-900">
                                            {{ profile ? (profile.firstName ~ ' ' ~ profile.lastName) : '—' }}
                                        </div>
                                        <div class="text-xs text-gray-500">{{ user.email }}</div>
                                    </div>
                                </div>
                            </td>

                            <td class="px-5 py-4">
                                {% if 'ROLE_ADMIN' in user.roles %}
                                    <span class="inline-block px-2.5 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-700">Admin</span>
                                {% elseif 'ROLE_MODERATOR' in user.roles %}
                                    <span class="inline-block px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-100 text-amber-700">Modérateur</span>
                                {% else %}
                                    <span class="inline-block px-2.5 py-1 rounded-full text-xs font-semibold bg-blue-100 text-blue-700">Étudiant</span>
                                {% endif %}
                            </td>

                            <td class="px-5 py-4">
                                {% if user.isVerified %}
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">
                                        <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                                        Vérifié
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-red-100 text-red-700">
                                        <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                                        Non vérifié
                                    </span>
                                {% endif %}
                            </td>

                            <td class="px-5 py-4 text-sm text-gray-700">{{ user.reviews|length }}</td>

                            <td class="px-5 py-4 text-sm text-gray-500">
                                {{ user.createdAt ? user.createdAt|date('d/m/Y') : '—' }}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
{% endblock %}
