{% extends 'base.html.twig' %}

{% block title %}Administration — Utilisateurs{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #f1f5f9;
            color: #1e293b;
        }

        .admin-header {
            background: #1e293b;
            color: #fff;
            padding: 1rem 2rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .admin-header h1 {
            font-size: 1.25rem;
            font-weight: 600;
        }

        .badge-admin {
            background: #ef4444;
            color: #fff;
            font-size: 0.7rem;
            font-weight: 700;
            padding: 0.2rem 0.5rem;
            border-radius: 4px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .container {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 0 1.5rem;
        }

        .page-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 0.25rem;
        }

        .page-subtitle {
            color: #64748b;
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
        }

        .stats {
            display: flex;
            gap: 1rem;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }

        .stat-card {
            background: #fff;
            border-radius: 8px;
            padding: 1rem 1.5rem;
            border: 1px solid #e2e8f0;
            min-width: 140px;
        }

        .stat-card .value {
            font-size: 1.75rem;
            font-weight: 700;
            line-height: 1;
        }

        .stat-card .label {
            font-size: 0.8rem;
            color: #64748b;
            margin-top: 0.25rem;
        }

        .stat-card.blue .value  { color: #3b82f6; }
        .stat-card.green .value { color: #22c55e; }
        .stat-card.orange .value{ color: #f97316; }
        .stat-card.red .value   { color: #ef4444; }

        .table-card {
            background: #fff;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            overflow: hidden;
        }

        .table-card table {
            width: 100%;
            border-collapse: collapse;
        }

        .table-card thead {
            background: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
        }

        .table-card th {
            padding: 0.85rem 1.25rem;
            text-align: left;
            font-size: 0.78rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #64748b;
        }

        .table-card td {
            padding: 0.9rem 1.25rem;
            border-bottom: 1px solid #f1f5f9;
            font-size: 0.9rem;
            vertical-align: middle;
        }

        .table-card tbody tr:last-child td {
            border-bottom: none;
        }

        .table-card tbody tr:hover {
            background: #f8fafc;
        }

        .user-cell {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #3b82f6;
            color: #fff;
            font-size: 0.85rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            text-transform: uppercase;
        }

        .user-name {
            font-weight: 600;
        }

        .user-email {
            font-size: 0.8rem;
            color: #64748b;
        }

        .role-badge {
            display: inline-block;
            padding: 0.2rem 0.6rem;
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .role-admin     { background: #fee2e2; color: #b91c1c; }
        .role-moderator { background: #fef3c7; color: #b45309; }
        .role-user      { background: #dbeafe; color: #1d4ed8; }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.2rem 0.6rem;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 500;
        }

        .status-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
        }

        .status-verified   { background: #dcfce7; color: #15803d; }
        .status-verified::before   { background: #22c55e; }
        .status-unverified { background: #fee2e2; color: #b91c1c; }
        .status-unverified::before { background: #ef4444; }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            color: #94a3b8;
        }

        .empty-state svg {
            width: 48px;
            height: 48px;
            margin: 0 auto 1rem;
            opacity: 0.4;
        }
    </style>
{% endblock %}

{% block body %}
    <header class="admin-header">
        <span class="badge-admin">Admin</span>
        <h1>Panneau d'administration</h1>
    </header>

    <div class="container">
        <h2 class="page-title">Gestion des utilisateurs</h2>
        <p class="page-subtitle">{{ users|length }} utilisateur{{ users|length > 1 ? 's' : '' }} au total</p>

        {# Stats rapides #}
        {% set totalVerified   = users|filter(u => u.isVerified)|length %}
        {% set totalAdmins     = users|filter(u => 'ROLE_ADMIN' in u.roles)|length %}
        {% set totalModerators = users|filter(u => 'ROLE_MODERATOR' in u.roles)|length %}

        <div class="stats">
            <div class="stat-card blue">
                <div class="value">{{ users|length }}</div>
                <div class="label">Total utilisateurs</div>
            </div>
            <div class="stat-card green">
                <div class="value">{{ totalVerified }}</div>
                <div class="label">Vérifiés</div>
            </div>
            <div class="stat-card orange">
                <div class="value">{{ totalModerators }}</div>
                <div class="label">Modérateurs</div>
            </div>
            <div class="stat-card red">
                <div class="value">{{ totalAdmins }}</div>
                <div class="label">Administrateurs</div>
            </div>
        </div>

        <div class="table-card">
            {% if users is empty %}
                <div class="empty-state">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                    </svg>
                    <p>Aucun utilisateur trouvé.</p>
                </div>
            {% else %}
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Utilisateur</th>
                            <th>Rôle</th>
                            <th>Statut</th>
                            <th>Avis</th>
                            <th>Inscrit le</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                            {% set profile = user.profile %}
                            {% set initials = profile ? (profile.firstName|first ~ profile.lastName|first) : user.email|first %}

                            <tr>
                                <td style="color:#94a3b8; font-size:0.8rem;">{{ user.id }}</td>

                                <td>
                                    <div class="user-cell">
                                        <div class="avatar">{{ initials|upper }}</div>
                                        <div>
                                            <div class="user-name">
                                                {{ profile ? (profile.firstName ~ ' ' ~ profile.lastName) : '—' }}
                                            </div>
                                            <div class="user-email">{{ user.email }}</div>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    {% if 'ROLE_ADMIN' in user.roles %}
                                        <span class="role-badge role-admin">Admin</span>
                                    {% elseif 'ROLE_MODERATOR' in user.roles %}
                                        <span class="role-badge role-moderator">Modérateur</span>
                                    {% else %}
                                        <span class="role-badge role-user">Utilisateur</span>
                                    {% endif %}
                                </td>

                                <td>
                                    {% if user.isVerified %}
                                        <span class="status-badge status-verified">Vérifié</span>
                                    {% else %}
                                        <span class="status-badge status-unverified">Non vérifié</span>
                                    {% endif %}
                                </td>

                                <td>{{ user.reviews|length }}</td>

                                <td style="color:#64748b; font-size:0.85rem;">
                                    {{ user.createdAt ? user.createdAt|date('d/m/Y') : '—' }}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>
    </div>
{% endblock %}
