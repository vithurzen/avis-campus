{% extends 'layout/admin.html.twig' %}

{% block title %}Audit — Administration{% endblock %}

{% block page_title %}Audit{% endblock %}

{% block content %}

<div class="mb-6">
    <h1 class="text-xl font-bold text-gray-900">Audit</h1>
    <p class="text-sm text-gray-500 mt-0.5">Historique technique de la plateforme : e-mails envoyés, appels API et actions de modération.</p>
</div>

{# ── Onglets ── #}
<div class="flex items-center gap-2 mb-6 flex-wrap">
    <button data-tab="emails" class="audit-tab active-tab px-4 py-1.5 rounded-full text-sm font-medium border transition">
        <i class="fa-solid fa-envelope mr-1.5"></i>E-mails ({{ emailLogs|length }})
    </button>
    <button data-tab="api" class="audit-tab px-4 py-1.5 rounded-full text-sm font-medium border border-gray-200 text-gray-600 hover:border-gray-400 transition">
        <i class="fa-solid fa-plug mr-1.5"></i>Appels API ({{ apiLogs|length }})
    </button>
    <button data-tab="moderation" class="audit-tab px-4 py-1.5 rounded-full text-sm font-medium border border-gray-200 text-gray-600 hover:border-gray-400 transition">
        <i class="fa-solid fa-gavel mr-1.5"></i>Modération ({{ moderationActions|length }})
    </button>
</div>

{# ── E-mails ── #}
<div class="audit-panel bg-white rounded-xl border border-gray-200 overflow-hidden" data-panel="emails">
    {% if emailLogs is empty %}
        <div class="text-center py-16 text-gray-400">
            <i class="fa-solid fa-envelope text-4xl mb-4 opacity-30"></i>
            <p class="text-sm">Aucun e-mail enregistré.</p>
        </div>
    {% else %}
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">#</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Destinataire</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Sujet</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Type</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Statut</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Envoyé le</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for log in emailLogs %}
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-5 py-3 text-sm text-gray-400">{{ log.id }}</td>
                            <td class="px-5 py-3 text-sm text-gray-900">{{ log.recipient }}</td>
                            <td class="px-5 py-3 text-sm text-gray-700 max-w-xs truncate">{{ log.subject }}</td>
                            <td class="px-5 py-3 text-sm text-gray-500">{{ log.type }}</td>
                            <td class="px-5 py-3">
                                {% if log.status == 'sent' %}
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">
                                        <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Envoyé
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-red-100 text-red-700">
                                        <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span> Échec
                                    </span>
                                {% endif %}
                            </td>
                            <td class="px-5 py-3 text-sm text-gray-500">{{ log.sentAt ? log.sentAt|date('d/m/Y H:i') : '—' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>

{# ── Appels API ── #}
<div class="audit-panel bg-white rounded-xl border border-gray-200 overflow-hidden hidden" data-panel="api">
    {% if apiLogs is empty %}
        <div class="text-center py-16 text-gray-400">
            <i class="fa-solid fa-plug text-4xl mb-4 opacity-30"></i>
            <p class="text-sm">Aucun appel API enregistré.</p>
        </div>
    {% else %}
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">#</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Utilisateur</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Endpoint</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Méthode</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Statut</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for log in apiLogs %}
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-5 py-3 text-sm text-gray-400">{{ log.id }}</td>
                            <td class="px-5 py-3 text-sm text-gray-700">{{ log.user ? log.user.email : 'Anonyme' }}</td>
                            <td class="px-5 py-3 text-sm text-gray-900 font-mono max-w-xs truncate">{{ log.endpoint }}</td>
                            <td class="px-5 py-3 text-sm text-gray-500">{{ log.requestType }}</td>
                            <td class="px-5 py-3">
                                {% if log.responseStatus and log.responseStatus < 300 %}
                                    <span class="inline-block px-2.5 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-700">{{ log.responseStatus }}</span>
                                {% elseif log.responseStatus and log.responseStatus < 500 %}
                                    <span class="inline-block px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-100 text-amber-700">{{ log.responseStatus }}</span>
                                {% else %}
                                    <span class="inline-block px-2.5 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-700">{{ log.responseStatus ?? '—' }}</span>
                                {% endif %}
                            </td>
                            <td class="px-5 py-3 text-sm text-gray-500">{{ log.createdAt ? log.createdAt|date('d/m/Y H:i') : '—' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>

{# ── Actions de modération ── #}
<div class="audit-panel bg-white rounded-xl border border-gray-200 overflow-hidden hidden" data-panel="moderation">
    {% if moderationActions is empty %}
        <div class="text-center py-16 text-gray-400">
            <i class="fa-solid fa-gavel text-4xl mb-4 opacity-30"></i>
            <p class="text-sm">Aucune action de modération enregistrée.</p>
        </div>
    {% else %}
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">#</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Modérateur</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Action</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Cible</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Raison</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for action in moderationActions %}
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-5 py-3 text-sm text-gray-400">{{ action.id }}</td>
                            <td class="px-5 py-3 text-sm text-gray-900">
                                {{ action.moderator ? (action.moderator.firstName ~ ' ' ~ action.moderator.lastName) : '—' }}
                            </td>
                            <td class="px-5 py-3">
                                <span class="inline-block px-2.5 py-1 rounded-full text-xs font-semibold bg-slate-100 text-slate-700">{{ action.action }}</span>
                            </td>
                            <td class="px-5 py-3 text-sm text-gray-500">
                                {% if action.review %}
                                    Avis « {{ action.review.title }} »
                                {% elseif action.comment %}
                                    Commentaire #{{ action.comment.id }}
                                {% elseif action.report %}
                                    Signalement #{{ action.report.id }}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td class="px-5 py-3 text-sm text-gray-600 max-w-sm truncate">{{ action.reason ?? '—' }}</td>
                            <td class="px-5 py-3 text-sm text-gray-500">{{ action.createdAt ? action.createdAt|date('d/m/Y H:i') : '—' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>

<script>
(function () {
    const tabs   = document.querySelectorAll('.audit-tab');
    const panels = document.querySelectorAll('.audit-panel');

    const on  = ['bg-brand', 'text-white', 'border-brand'];
    const off = ['border-gray-200', 'text-gray-600'];

    tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            tabs.forEach(t => {
                t.classList.remove(...on, 'active-tab');
                t.classList.add(...off);
            });
            tab.classList.remove(...off);
            tab.classList.add(...on, 'active-tab');

            panels.forEach(p => p.classList.toggle('hidden', p.dataset.panel !== tab.dataset.tab));
        });
    });

    document.querySelector('[data-tab="emails"]').classList.add(...on);
    document.querySelector('[data-tab="emails"]').classList.remove(...off);
})();
</script>
{% endblock %}
