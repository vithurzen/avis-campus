{% extends 'layout/admin.html.twig' %}

{% block title %}Gestion des avis — Admin{% endblock %}

{% block content %}

<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-xl font-bold text-gray-900">Gestion des avis</h1>
        <p class="text-sm text-gray-500 mt-0.5">{{ reviews|length }} avis au total</p>
    </div>
    <div class="flex items-center gap-2">
        <button data-filter="all"      class="filter-btn px-3 py-1.5 rounded-full text-xs font-medium border transition">Tous</button>
        <button data-filter="approved" class="filter-btn px-3 py-1.5 rounded-full text-xs font-medium border border-gray-200 text-gray-600 hover:border-green-400 hover:text-green-700 transition">Approuvés</button>
        <button data-filter="hidden"   class="filter-btn px-3 py-1.5 rounded-full text-xs font-medium border border-gray-200 text-gray-600 hover:border-red-400 hover:text-red-600 transition">Masqués</button>
        <button data-filter="pending"  class="filter-btn px-3 py-1.5 rounded-full text-xs font-medium border border-gray-200 text-gray-600 hover:border-amber-400 hover:text-amber-600 transition">En attente</button>
    </div>
</div>

{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="mb-4 text-sm px-4 py-3 rounded-lg border
            {{ label == 'success' ? 'bg-green-50 border-green-200 text-green-700' : '' }}
            {{ label == 'error'   ? 'bg-red-50 border-red-200 text-red-600' : '' }}">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

{% if reviews is empty %}
    <div class="text-center py-24 text-gray-400 bg-white rounded-2xl border border-gray-200">
        <i class="fa-solid fa-star text-4xl mb-3 opacity-20"></i>
        <p class="text-sm">Aucun avis.</p>
    </div>
{% else %}
    <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
        <table class="w-full border-collapse">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">#</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Avis</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Cours</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Note</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Statut</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Date</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for review in reviews %}
                    <tr class="review-row hover:bg-gray-50 transition" data-status="{{ review.status }}">

                        <td class="px-4 py-3 text-xs text-gray-400">{{ review.id }}</td>

                        <td class="px-4 py-3 max-w-xs">
                            <a href="{{ path('app_review_show', { id: review.id }) }}"
                               class="text-sm font-medium text-gray-900 hover:text-brand transition line-clamp-1">
                                {{ review.title }}
                            </a>
                            <p class="text-xs text-gray-400 mt-0.5 truncate">
                                {% set profile = review.user.profile %}
                                {{ profile ? (profile.firstName ~ ' ' ~ profile.lastName) : review.user.email }}
                            </p>
                        </td>

                        <td class="px-4 py-3 text-sm text-gray-600">
                            {% if review.course %}
                                <a href="{{ path('app_course_show', { id: review.course.id }) }}" class="hover:text-brand transition">
                                    {{ review.course.title }}
                                </a>
                            {% else %}—{% endif %}
                        </td>

                        <td class="px-4 py-3">
                            {% if review.rating %}
                                <span class="text-sm text-amber-400 tracking-tight">
                                    {% for i in 1..5 %}{{ i <= review.rating ? '★' : '☆' }}{% endfor %}
                                </span>
                                <span class="text-xs text-gray-400 ml-1">{{ review.rating }}/5</span>
                            {% else %}
                                <span class="text-xs text-gray-300">—</span>
                            {% endif %}
                        </td>

                        <td class="px-4 py-3">
                            {% if review.status == 'approved' %}
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">
                                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Approuvé
                                </span>
                            {% elseif review.status == 'hidden' %}
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-600">
                                    <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span> Masqué
                                </span>
                            {% elseif review.status == 'pending' %}
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">
                                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span> En attente
                                </span>
                            {% elseif review.status == 'rejected' %}
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
                                    <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span> Rejeté
                                </span>
                            {% endif %}
                        </td>

                        <td class="px-4 py-3 text-xs text-gray-400">
                            {{ review.createdAt ? review.createdAt|date('d/m/Y') : '—' }}
                        </td>

                        <td class="px-4 py-3 text-right">
                            {# Formulaires cachés soumis par les modales #}
                            {% if review.status != 'hidden' %}
                                <form id="form-hide-{{ review.id }}" method="post"
                                      action="{{ path('app_admin_review_hide', { id: review.id }) }}" class="hidden">
                                    <input type="hidden" name="_token" value="{{ csrf_token('admin_review_' ~ review.id) }}">
                                </form>
                                <button type="button"
                                        data-modal="hide"
                                        data-form="form-hide-{{ review.id }}"
                                        data-title="{{ review.title|e('html_attr') }}"
                                        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium bg-red-50 text-red-600 hover:bg-red-100 transition">
                                    <i class="fa-solid fa-eye-slash"></i> Signaler
                                </button>
                            {% else %}
                                <form id="form-approve-{{ review.id }}" method="post"
                                      action="{{ path('app_admin_review_approve', { id: review.id }) }}" class="hidden">
                                    <input type="hidden" name="_token" value="{{ csrf_token('admin_review_' ~ review.id) }}">
                                </form>
                                <button type="button"
                                        data-modal="approve"
                                        data-form="form-approve-{{ review.id }}"
                                        data-title="{{ review.title|e('html_attr') }}"
                                        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium bg-green-50 text-green-700 hover:bg-green-100 transition">
                                    <i class="fa-solid fa-eye"></i> Restaurer
                                </button>
                            {% endif %}
                        </td>

                    </tr>
                {% endfor %}
            </tbody>
        </table>

        <p class="text-center text-sm text-gray-400 py-10 hidden" id="no-results">Aucun avis pour ce filtre.</p>
    </div>
{% endif %}

{# ── Modale Signaler ── #}
<div id="modal-hide" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="modal-hide-backdrop"></div>
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-md mx-4 p-6 animate-fade-in">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center shrink-0">
                <i class="fa-solid fa-eye-slash text-red-500"></i>
            </div>
            <div>
                <h3 class="font-semibold text-gray-900">Signaler cet avis</h3>
                <p class="text-xs text-gray-400">L'avis sera masqué et ne sera plus visible publiquement.</p>
            </div>
        </div>
        <p class="text-sm text-gray-600 bg-gray-50 rounded-xl px-4 py-3 mb-6">
            « <span id="modal-hide-title" class="font-medium text-gray-900"></span> »
        </p>
        <div class="flex items-center justify-end gap-3">
            <button type="button" id="modal-hide-cancel"
                    class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 transition">
                Annuler
            </button>
            <button type="button" id="modal-hide-confirm"
                    class="px-5 py-2 text-sm font-semibold bg-red-500 hover:bg-red-600 text-white rounded-full transition">
                Oui, signaler
            </button>
        </div>
    </div>
</div>

{# ── Modale Restaurer ── #}
<div id="modal-approve" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="modal-approve-backdrop"></div>
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-md mx-4 p-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center shrink-0">
                <i class="fa-solid fa-eye text-green-600"></i>
            </div>
            <div>
                <h3 class="font-semibold text-gray-900">Restaurer cet avis</h3>
                <p class="text-xs text-gray-400">L'avis redeviendra visible publiquement.</p>
            </div>
        </div>
        <p class="text-sm text-gray-600 bg-gray-50 rounded-xl px-4 py-3 mb-6">
            « <span id="modal-approve-title" class="font-medium text-gray-900"></span> »
        </p>
        <div class="flex items-center justify-end gap-3">
            <button type="button" id="modal-approve-cancel"
                    class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 transition">
                Annuler
            </button>
            <button type="button" id="modal-approve-confirm"
                    class="px-5 py-2 text-sm font-semibold bg-green-600 hover:bg-green-700 text-white rounded-full transition">
                Oui, restaurer
            </button>
        </div>
    </div>
</div>

<script>
(function () {
    /* ── Filtres ── */
    const filterBtns = document.querySelectorAll('.filter-btn');
    const rows       = document.querySelectorAll('.review-row');
    const noRes      = document.getElementById('no-results');
    const on  = ['bg-brand', 'text-white', 'border-brand'];
    const off = ['border-gray-200', 'text-gray-600'];

    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            filterBtns.forEach(b => { b.classList.remove(...on); b.classList.add(...off); });
            btn.classList.remove(...off); btn.classList.add(...on);
            let visible = 0;
            rows.forEach(row => {
                const show = btn.dataset.filter === 'all' || row.dataset.status === btn.dataset.filter;
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            if (noRes) noRes.classList.toggle('hidden', visible > 0);
        });
    });
    document.querySelector('[data-filter="all"]').classList.add(...on);

    /* ── Modales ── */
    let pendingForm = null;

    function openModal(id, title, formId) {
        pendingForm = document.getElementById(formId);
        document.getElementById('modal-' + id + '-title').textContent = title;
        document.getElementById('modal-' + id).classList.remove('hidden');
    }

    function closeModal(id) {
        document.getElementById('modal-' + id).classList.add('hidden');
        pendingForm = null;
    }

    ['hide', 'approve'].forEach(type => {
        document.getElementById('modal-' + type + '-cancel')
            .addEventListener('click', () => closeModal(type));
        document.getElementById('modal-' + type + '-backdrop')
            .addEventListener('click', () => closeModal(type));
        document.getElementById('modal-' + type + '-confirm')
            .addEventListener('click', () => { if (pendingForm) pendingForm.submit(); });
    });

    document.querySelectorAll('[data-modal]').forEach(btn => {
        btn.addEventListener('click', () => openModal(btn.dataset.modal, btn.dataset.title, btn.dataset.form));
    });

    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') { closeModal('hide'); closeModal('approve'); }
    });
})();
</script>

{% endblock %}
