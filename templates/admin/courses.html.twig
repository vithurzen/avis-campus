{% extends 'layout/admin.html.twig' %}

{% block title %}Cours — Administration{% endblock %}

{% block content %}

<div class="flex items-center justify-between gap-4 mb-6 flex-wrap">
    <div>
        <h1 class="text-xl font-bold text-gray-900">Cours</h1>
        <p class="text-sm text-gray-500 mt-0.5" id="course-count">
            {{ courses|length }} cours au total
        </p>
    </div>
    <div class="relative w-64">
        <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"></i>
        <input type="search" id="course-search" placeholder="Rechercher…"
               class="w-full pl-9 pr-3 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand bg-white">
    </div>
</div>

{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="mb-4 text-sm px-4 py-3 rounded-lg border
            {{ label == 'success' ? 'bg-green-50 border-green-200 text-green-700' : '' }}
            {{ label == 'error'   ? 'bg-red-50 border-red-200 text-red-600' : '' }}">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

{% if courses is empty %}
    <div class="text-center py-20 text-gray-400 bg-white rounded-2xl border border-gray-200">
        <i class="fa-solid fa-book text-4xl mb-3 opacity-20"></i>
        <p class="text-sm">Aucun cours pour le moment.</p>
    </div>
{% else %}
    <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
        <table class="w-full border-collapse">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Cours</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Formation / Semestre</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Professeurs</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Avis</th>
                    <th class="px-5 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for course in courses %}
                    <tr class="course-row hover:bg-gray-50 transition"
                        data-search="{{ course.title|lower }} {{ course.semester and course.semester.formation ? course.semester.formation.name|lower : '' }}">

                        <td class="px-5 py-3 max-w-xs">
                            <a href="{{ path('app_course_show', { id: course.id }) }}"
                               class="text-sm font-medium text-gray-900 hover:text-brand transition line-clamp-1">
                                {{ course.title }}
                            </a>
                        </td>

                        <td class="px-5 py-3 text-sm text-gray-500">
                            {% if course.semester %}
                                {{ course.semester.formation ? course.semester.formation.name : '—' }}
                                <span class="text-gray-300">·</span> {{ course.semester.name }}
                            {% else %}—{% endif %}
                        </td>

                        <td class="px-5 py-3">
                            {% if course.teachers is empty %}
                                <span class="text-xs text-gray-300">Aucun</span>
                            {% else %}
                                <div class="flex flex-wrap gap-1">
                                    {% for teacher in course.teachers|slice(0, 2) %}
                                        <span class="inline-block px-2 py-0.5 rounded-full text-xs bg-gray-100 text-gray-600">
                                            {{ teacher.firstName }} {{ teacher.lastName }}
                                        </span>
                                    {% endfor %}
                                    {% if course.teachers|length > 2 %}
                                        <span class="inline-block px-2 py-0.5 rounded-full text-xs bg-gray-100 text-gray-400">
                                            +{{ course.teachers|length - 2 }}
                                        </span>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </td>

                        <td class="px-5 py-3 text-sm text-gray-500">
                            {{ course.reviews|length }} avis
                        </td>

                        <td class="px-5 py-3 text-right">
                            {% if course.reviews is empty %}
                                {# Formulaire caché soumis par la modale #}
                                <form id="form-delete-course-{{ course.id }}" method="post"
                                      action="{{ path('app_admin_course_delete', { id: course.id }) }}" class="hidden">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_course_' ~ course.id) }}">
                                </form>
                                <button type="button"
                                        data-form="form-delete-course-{{ course.id }}"
                                        data-name="{{ course.title }}"
                                        class="delete-btn inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium bg-red-50 text-red-600 hover:bg-red-100 transition">
                                    <i class="fa-solid fa-trash"></i> Supprimer
                                </button>
                            {% else %}
                                <span title="Impossible de supprimer un cours qui a des avis"
                                      class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium bg-gray-100 text-gray-400 cursor-not-allowed">
                                    <i class="fa-solid fa-trash"></i> Supprimer
                                </span>
                            {% endif %}
                        </td>

                    </tr>
                {% endfor %}
            </tbody>
        </table>
        <p class="text-center text-sm text-gray-400 py-8 hidden" id="no-results">Aucun cours trouvé.</p>
    </div>
{% endif %}

{# ── Modale suppression ── #}
<div id="modal-delete" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="modal-backdrop"></div>
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-md mx-4 p-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center shrink-0">
                <i class="fa-solid fa-trash text-red-500"></i>
            </div>
            <div>
                <h3 class="font-semibold text-gray-900">Supprimer ce cours</h3>
                <p class="text-xs text-gray-400">Cette action est irréversible.</p>
            </div>
        </div>
        <p class="text-sm text-gray-600 bg-gray-50 rounded-xl px-4 py-3 mb-6">
            Supprimer <span id="modal-course-name" class="font-semibold text-gray-900"></span> ?
        </p>
        <div class="flex items-center justify-end gap-3">
            <button type="button" id="modal-cancel"
                    class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 transition">
                Annuler
            </button>
            <button type="button" id="modal-confirm"
                    class="px-5 py-2 text-sm font-semibold bg-red-500 hover:bg-red-600 text-white rounded-full transition">
                Oui, supprimer
            </button>
        </div>
    </div>
</div>

<script>
(function () {
    /* ── Recherche ── */
    const input   = document.getElementById('course-search');
    const rows    = document.querySelectorAll('.course-row');
    const counter = document.getElementById('course-count');
    const noRes   = document.getElementById('no-results');

    if (input) {
        input.addEventListener('input', () => {
            const q = input.value.trim().toLowerCase();
            let n = 0;
            rows.forEach(row => {
                const match = !q || row.dataset.search.includes(q);
                row.style.display = match ? '' : 'none';
                if (match) n++;
            });
            if (noRes) noRes.classList.toggle('hidden', n > 0);
            if (counter) counter.textContent = n + ' cours au total';
        });
    }

    /* ── Modale suppression ── */
    let pendingForm = null;

    document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            pendingForm = document.getElementById(btn.dataset.form);
            document.getElementById('modal-course-name').textContent = btn.dataset.name;
            document.getElementById('modal-delete').classList.remove('hidden');
        });
    });

    document.getElementById('modal-cancel').addEventListener('click', close);
    document.getElementById('modal-backdrop').addEventListener('click', close);
    document.getElementById('modal-confirm').addEventListener('click', () => {
        if (pendingForm) pendingForm.submit();
    });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });

    function close() {
        document.getElementById('modal-delete').classList.add('hidden');
        pendingForm = null;
    }
})();
</script>

{% endblock %}
