{% extends 'layout/app.html.twig' %}

{% block title %}Modération — Avis Campus{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">

    <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Modération des avis</h1>
        <p class="text-sm text-gray-500 mt-1">{{ reviews|length }} avis en attente de validation</p>
    </div>

    {% if reviews is empty %}
        <div class="text-center py-24 text-gray-400 bg-white rounded-2xl border border-gray-200">
            <i class="fa-solid fa-clipboard-check text-4xl mb-3 opacity-20"></i>
            <p class="text-sm">Aucun avis en attente.</p>
        </div>
    {% else %}
        <div class="space-y-4">
            {% for review in reviews %}
                <div class="bg-white rounded-2xl border border-gray-200 p-6">
                    <div class="flex items-start justify-between gap-4 mb-3">
                        <div>
                            <h2 class="font-semibold text-gray-900">{{ review.title }}</h2>
                            <p class="text-xs text-gray-400 mt-0.5">
                                {% set profile = review.user.profile %}
                                {{ profile ? (profile.firstName ~ ' ' ~ profile.lastName) : review.user.email }}
                                {% if review.course %}
                                    · <a href="{{ path('app_course_show', { id: review.course.id }) }}" class="hover:text-brand transition">{{ review.course.title }}</a>
                                {% endif %}
                                · {{ review.createdAt ? review.createdAt|date('d/m/Y H:i') : '' }}
                            </p>
                        </div>
                        {% if review.rating %}
                            <span class="text-sm text-amber-400 tracking-tight shrink-0">
                                {% for i in 1..5 %}{{ i <= review.rating ? '★' : '☆' }}{% endfor %}
                            </span>
                        {% endif %}
                    </div>

                    <p class="text-sm text-gray-600 mb-4 whitespace-pre-line">{{ review.content }}</p>

                    <div class="flex items-center justify-end gap-3">
                        <form method="post" action="{{ path('app_moderation_review_approve', { id: review.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('moderate' ~ review.id) }}">
                            <button type="submit"
                                    class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-xs font-semibold bg-green-50 text-green-700 hover:bg-green-100 transition">
                                <i class="fa-solid fa-check"></i> Approuver
                            </button>
                        </form>

                        <button type="button"
                                data-modal-open="reject-{{ review.id }}"
                                class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-xs font-semibold bg-red-50 text-red-600 hover:bg-red-100 transition">
                            <i class="fa-solid fa-xmark"></i> Rejeter
                        </button>
                    </div>
                </div>

                {# ── Modale Rejeter ── #}
                <div id="modal-reject-{{ review.id }}" class="fixed inset-0 z-50 flex items-center justify-center hidden">
                    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" data-modal-close="reject-{{ review.id }}"></div>
                    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-md mx-4 p-6">
                        <h3 class="font-semibold text-gray-900 mb-1">Rejeter cet avis</h3>
                        <p class="text-xs text-gray-400 mb-4">« {{ review.title }} »</p>
                        <form method="post" action="{{ path('app_moderation_review_reject', { id: review.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('moderate' ~ review.id) }}">
                            <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">
                                Motif <span class="text-xs font-normal text-gray-400 normal-case">(optionnel)</span>
                            </label>
                            <textarea name="reason" rows="3"
                                      class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand resize-none mb-4"
                                      placeholder="Précisez le motif du rejet…"></textarea>
                            <div class="flex items-center justify-end gap-3">
                                <button type="button" data-modal-close="reject-{{ review.id }}"
                                        class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 transition">
                                    Annuler
                                </button>
                                <button type="submit"
                                        class="px-5 py-2 text-sm font-semibold bg-red-500 hover:bg-red-600 text-white rounded-full transition">
                                    Rejeter l'avis
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

</div>

<script>
document.querySelectorAll('[data-modal-open]').forEach((btn) => {
    btn.addEventListener('click', () => {
        document.getElementById('modal-' + btn.dataset.modalOpen).classList.remove('hidden');
    });
});
document.querySelectorAll('[data-modal-close]').forEach((btn) => {
    btn.addEventListener('click', () => {
        document.getElementById('modal-' + btn.dataset.modalClose).classList.add('hidden');
    });
});
document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
        document.querySelectorAll('[id^="modal-reject-"]').forEach((el) => el.classList.add('hidden'));
    }
});
</script>
{% endblock %}
