<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Avis Campus{% endblock %}</title>
        <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%2024%2024'%3E%3Crect%20width='24'%20height='24'%20rx='5'%20fill='%236366F1'/%3E%3Cpolygon%20points='12,5%2021,9.5%2012,14%203,9.5'%20fill='white'/%3E%3Cpath%20d='M7,11.3%20L7,15.5%20C7,17%209.2,18.3%2012,18.3%20C14.8,18.3%2017,17%2017,15.5%20L17,11.3%20L12,13.6%20Z'%20fill='white'/%3E%3Cline%20x1='21'%20y1='9.5'%20x2='21'%20y2='14'%20stroke='white'%20stroke-width='1'/%3E%3Ccircle%20cx='21'%20cy='14.6'%20r='1'%20fill='white'/%3E%3C/svg%3E">
