{% extends 'layout/app.html.twig' %}

{% block title %}Mot de passe oublié — Avis Campus{% endblock %}

{% block content %}
<div class="flex items-center justify-center bg-gray-50 py-16 px-4 min-h-[calc(100vh-8rem)]">
    <div class="w-full max-w-md">

        <div class="text-center mb-8">
            <h1 class="text-2xl font-bold text-gray-900">Mot de passe oublié ?</h1>
            <p class="text-sm text-gray-500 mt-1">Saisissez votre email pour recevoir un lien de réinitialisation</p>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">

            {{ form_start(requestForm, { attr: { class: 'space-y-5' } }) }}

                <div>
                    {{ form_label(requestForm.email, 'Email', {
                        label_attr: { class: 'block text-xs font-bold text-gray-700 uppercase tracking-wide mb-1.5' }
                    }) }}
                    {{ form_widget(requestForm.email, {
                        attr: { class: 'w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand bg-white' }
                    }) }}
                    <div class="mt-1.5 text-xs text-red-600 space-y-0.5">{{ form_errors(requestForm.email) }}</div>
                </div>

                <button type="submit"
                        class="w-full bg-brand hover:bg-brandHover text-white font-semibold text-sm py-2.5 rounded-full transition">
                    Envoyer le lien
                </button>

            {{ form_end(requestForm) }}

        </div>

        <p class="text-center text-sm text-gray-500 mt-6">
            <a href="{{ path('app_login') }}" class="text-brand font-semibold hover:underline">Retour à la connexion</a>
        </p>

    </div>
</div>
{% endblock %}
