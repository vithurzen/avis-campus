{% extends 'layout/app.html.twig' %}

{% block title %}Nouveau mot de passe — Avis Campus{% endblock %}

{% block content %}
<div class="flex items-center justify-center bg-gray-50 py-16 px-4 min-h-[calc(100vh-8rem)]">
    <div class="w-full max-w-md">

        <div class="text-center mb-8">
            <h1 class="text-2xl font-bold text-gray-900">Nouveau mot de passe</h1>
            <p class="text-sm text-gray-500 mt-1">Choisissez un nouveau mot de passe pour votre compte</p>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">

            {{ form_start(resetForm, { attr: { class: 'space-y-5' } }) }}

                <div>
                    {{ form_label(resetForm.plainPassword.first, 'Nouveau mot de passe', {
                        label_attr: { class: 'block text-xs font-bold text-gray-700 uppercase tracking-wide mb-1.5' }
                    }) }}
                    {{ form_widget(resetForm.plainPassword.first, {
                        attr: { class: 'w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand bg-white' }
                    }) }}
                    <div class="mt-1.5 text-xs text-red-600 space-y-0.5">{{ form_errors(resetForm.plainPassword.first) }}</div>
                </div>

                <div>
                    {{ form_label(resetForm.plainPassword.second, 'Confirmez le mot de passe', {
                        label_attr: { class: 'block text-xs font-bold text-gray-700 uppercase tracking-wide mb-1.5' }
                    }) }}
                    {{ form_widget(resetForm.plainPassword.second, {
                        attr: { class: 'w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand bg-white' }
                    }) }}
                    <div class="mt-1.5 text-xs text-red-600 space-y-0.5">{{ form_errors(resetForm.plainPassword.second) }}</div>
                </div>

                <button type="submit"
                        class="w-full bg-brand hover:bg-brandHover text-white font-semibold text-sm py-2.5 rounded-full transition">
                    Réinitialiser le mot de passe
                </button>

            {{ form_end(resetForm) }}

        </div>

    </div>
</div>
{% endblock %}
