{% extends 'layout/app.html.twig' %}

{% block title %}Connexion — Avis Campus{% endblock %}

{% block content %}
<div class="flex items-center justify-center bg-gray-50 py-16 px-4 min-h-[calc(100vh-8rem)]">
    <div class="w-full max-w-md">

        <div class="text-center mb-8">
            <h1 class="text-2xl font-bold text-gray-900">Bon retour !</h1>
            <p class="text-sm text-gray-500 mt-1">Connectez-vous à votre compte</p>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">

            {% if error %}
                <div class="mb-5 text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-4 py-3">
                    <i class="fa-solid fa-circle-exclamation mr-1"></i>
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post" class="space-y-5">

                <div>
                    <label for="username" class="block text-xs font-bold text-gray-700 uppercase tracking-wide mb-1.5">
                        Email
                    </label>
                    <input type="email" id="username" name="_username"
                           value="{{ last_username }}"
                           autocomplete="email" required autofocus
                           class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand bg-white">
                </div>

                <div>
                    <label for="password" class="block text-xs font-bold text-gray-700 uppercase tracking-wide mb-1.5">
                        Mot de passe
                    </label>
                    <input type="password" id="password" name="_password"
                           autocomplete="current-password" required
                           class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand bg-white">
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button type="submit"
                        class="w-full bg-brand hover:bg-brandHover text-white font-semibold text-sm py-2.5 rounded-full transition">
                    Se connecter
                </button>

            </form>
        </div>

        <p class="text-center text-sm text-gray-500 mt-6">
            Pas encore de compte ?
            <a href="{{ path('app_register') }}" class="text-brand font-semibold hover:underline">S'inscrire</a>
        </p>

    </div>
</div>
{% endblock %}
