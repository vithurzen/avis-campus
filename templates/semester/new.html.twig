{% extends 'layout/app.html.twig' %}

{% block title %}Nouveau semestre — Avis Campus{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto px-4 sm:px-6 py-10">

    <div class="mb-8">
        {% if formation %}
            <a href="{{ path('app_formation_show', { id: formation.id }) }}" class="text-sm text-gray-500 hover:text-brand transition">
                <i class="fa-solid fa-arrow-left mr-1"></i> Retour à {{ formation.name }}
            </a>
        {% else %}
            <a href="{{ path('app_formation_index') }}" class="text-sm text-gray-500 hover:text-brand transition">
                <i class="fa-solid fa-arrow-left mr-1"></i> Retour aux formations
            </a>
        {% endif %}
        <h1 class="text-2xl font-bold text-gray-900 mt-4">Nouveau semestre</h1>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 p-8">
        {{ form_start(form, { attr: { class: 'space-y-6' } }) }}

            {% if formation %}
                <div>
                    <p class="block text-xs font-bold text-gray-700 uppercase tracking-wide mb-1.5">Formation</p>
                    <p class="text-sm text-gray-900 px-3 py-2.5 bg-gray-50 border border-gray-200 rounded-lg">{{ formation.name }}</p>
                </div>
            {% else %}
                <div>
                    {{ form_label(form.formation, 'Formation', {
                        label_attr: { class: 'block text-xs font-bold text-gray-700 uppercase tracking-wide mb-1.5' }
                    }) }}
                    {{ form_widget(form.formation, {
                        attr: { class: 'w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand bg-white' }
                    }) }}
                    <div class="mt-1.5 text-xs text-red-600">{{ form_errors(form.formation) }}</div>
                </div>
            {% endif %}

            <div class="grid grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.number, 'Numéro', {
                        label_attr: { class: 'block text-xs font-bold text-gray-700 uppercase tracking-wide mb-1.5' }
                    }) }}
                    {{ form_widget(form.number, {
                        attr: { class: 'w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand bg-white' }
                    }) }}
                    <div class="mt-1.5 text-xs text-red-600">{{ form_errors(form.number) }}</div>
                </div>
                <div>
                    {{ form_label(form.name, 'Nom', {
                        label_attr: { class: 'block text-xs font-bold text-gray-700 uppercase tracking-wide mb-1.5' }
                    }) }}
                    {{ form_widget(form.name, {
                        attr: { class: 'w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand bg-white', placeholder: 'Ex: Semestre 1' }
                    }) }}
                    <div class="mt-1.5 text-xs text-red-600">{{ form_errors(form.name) }}</div>
                </div>
            </div>

            <div class="flex items-center justify-between pt-2">
                {% if formation %}
                    <a href="{{ path('app_formation_show', { id: formation.id }) }}"
                       class="text-sm font-medium text-gray-500 hover:text-gray-700 transition px-4 py-2 rounded-full border border-gray-200 hover:bg-gray-50">
                        <i class="fa-solid fa-check mr-1"></i> Terminer
                    </a>
                {% else %}
                    <a href="{{ path('app_formation_index') }}"
                       class="text-sm text-gray-500 hover:text-gray-700 transition px-4 py-2">
                        Annuler
                    </a>
                {% endif %}
                <button type="submit"
                        class="bg-brand hover:bg-brandHover text-white font-semibold text-sm px-6 py-2.5 rounded-full transition">
                    <i class="fa-solid fa-plus mr-1.5"></i> Ajouter ce semestre
                </button>
            </div>

        {{ form_end(form) }}
    </div>

</div>
{% endblock %}
